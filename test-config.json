{
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "dns": {
    "servers": [
      {
        "tag": "google",
        "address": "8.8.8.8",
        "detachable": true
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "google",
        "disable_cache": true
      }
    ]
  },
  "route": {
    "rules": [
      {
        "domain": [
          "google.com"
        ],
        "outbound": "proxy"
      }
    ]
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    }
  }
}

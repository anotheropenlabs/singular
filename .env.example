# SingUI Environment Configuration

# JWT Secret for authentication tokens
# Generate a secure random string for production
JWT_SECRET=

# SQLite database path
DATABASE_PATH=./data/singui.db

# sing-box binary path (absolute path recommended)
SINGBOX_BINARY_PATH=/usr/local/bin/sing-box

# sing-box configuration file path
SINGBOX_CONFIG_PATH=./config/config.json
